{
  "name": "matriz-nodes",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:web": "npm --workspace @matriz/web run dev",
    "dev:api": "npm --workspace @matriz/api run dev",
    "build": "npm run build --workspaces",
    "generate": "node scripts/generateGraph.mjs",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@matriz/shared": "1.0.0"
  }
}